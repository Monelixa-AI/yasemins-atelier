generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  CONTENT_EDITOR
  ORDER_MANAGER
  CRM_MANAGER
  FINANCE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  IYZICO
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum DeliveryStatus {
  SCHEDULED
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum OccasionSlug {
  MISAFIR_AGIRMA
  KADIN_GUNLERI
  DOGUM_GUNU
  IS_YEMEGI
  KURUMSAL_HEDIYE
  EV_PARTISI
  KAHVALTI
  SAGLIKLI
  MEVSIMSEL
}

enum PaymentProvider {
  STRIPE
  IYZICO
  CASH
  POS_ON_DELIVERY
}

enum PaymentMethodType {
  CREDIT_CARD
  DEBIT_CARD
  CASH
  POS_ON_DELIVERY
}

// ─── MODELS ─────────────────────────────────────────────

model AdminUser {
  id               String     @id @default(cuid())
  email            String     @unique
  name             String
  passwordHash     String
  role             Role       @default(CONTENT_EDITOR)
  isActive         Boolean    @default(true)
  lastLoginAt      DateTime?
  twoFactorSecret  String?
  twoFactorEnabled Boolean    @default(false)
  auditLogs        AuditLog[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model User {
  id              String               @id @default(cuid())
  email           String               @unique
  name            String?
  phone           String?
  passwordHash    String?
  emailVerified   DateTime?
  image           String?
  birthDate       DateTime?
  isActive        Boolean              @default(true)
  isCorporate     Boolean              @default(false)
  companyName     String?
  taxNumber       String?
  loyaltyPoints   Int                  @default(0)
  loyaltyTier     LoyaltyTier          @default(BRONZE)
  totalSpent      Decimal              @default(0) @db.Decimal(10, 2)
  orderCount      Int                  @default(0)
  referralCode    String               @unique @default(cuid())
  referredById    String?
  referredBy      User?                @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]               @relation("Referrals")
  addresses       Address[]
  orders          Order[]
  reviews         Review[]
  wishlistItems   WishlistItem[]
  loyaltyTxns     LoyaltyTransaction[]
  crmNotes        CRMNote[]
  emailConsent    Boolean              @default(false)
  smsConsent      Boolean              @default(false)
  consentDate     DateTime?
  consentSource   String?
  segments        CustomerSegment[]    @relation("SegmentUsers")
  tags            CustomerTag[]        @relation("TagUsers")
  aiConversations AIConversation[]
  bookings        ServiceBooking[]
  referralsMade     Referral[]         @relation("ReferralsMade")
  referralReceived  Referral?          @relation("ReferralReceived")
  notificationPrefs NotificationPreference?
  corporateAccount  CorporateAccount?
  corporateMemberships CorporateMember[]
  consentRecords      ConsentRecord[]
  deletionRequests    DataDeletionRequest[]
  accessRequests      DataAccessRequest[]
  dataProcessingRecords DataProcessingRecord[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model Address {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  district     String
  city         String   @default("İstanbul")
  isDefault    Boolean  @default(false)
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  products    Product[]
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Occasion {
  id          String            @id @default(cuid())
  slug        OccasionSlug      @unique
  name        String
  description String?
  longDesc    String?
  imageUrl    String?
  colorTheme  String?
  sortOrder   Int               @default(0)
  isActive    Boolean           @default(true)
  metaTitle   String?
  metaDesc    String?
  products    OccasionProduct[]
  blogPosts   BlogPost[]        @relation("OccasionPosts")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Product {
  id                  String              @id @default(cuid())
  name                String
  slug                String              @unique
  shortDesc           String
  longDesc            String?
  status              ProductStatus       @default(ACTIVE)
  basePrice           Decimal             @db.Decimal(10, 2)
  costPrice           Decimal?            @db.Decimal(10, 2)
  isFeatured          Boolean             @default(false)
  isNewBadge          Boolean             @default(false)
  newBadgeUntil       DateTime?
  requiresCustomOrder Boolean             @default(false)
  maxDailyOrders      Int?
  leadTimeHours       Int                 @default(24)
  shelfLifeHours      Int?
  ingredients         String?
  isVegan             Boolean             @default(false)
  isVegetarian        Boolean             @default(false)
  isGlutenFree        Boolean             @default(false)
  isLactoseFree       Boolean             @default(false)
  isHalal             Boolean             @default(false)
  allergens           String[]
  weightGrams         Int?
  categoryId          String?
  category            Category?           @relation(fields: [categoryId], references: [id])
  occasions           OccasionProduct[]
  collections         CollectionProduct[]
  variants            ProductVariant[]
  images              ProductImage[]
  orderItems          OrderItem[]
  reviews             Review[]
  wishlistItems       WishlistItem[]
  bundleItems         BundleItem[]
  crossSells          Product[]           @relation("CrossSells")
  crossSoldBy         Product[]           @relation("CrossSells")
  metaTitle           String?
  metaDesc            String?
  sortOrder           Int                 @default(0)
  avgRating           Decimal?            @db.Decimal(3, 2)
  reviewCount         Int                 @default(0)
  isNaturel           Boolean             @default(false)
  stockCount          Int?
  lowStockAlert       Int?
  shippingClass       String?
  isShippable         Boolean             @default(false)
  stockMovements      StockMovement[]
  flashSaleProducts   FlashSaleProduct[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  priceAdd   Decimal     @default(0) @db.Decimal(10, 2)
  isDefault  Boolean     @default(false)
  sortOrder  Int         @default(0)
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model OccasionProduct {
  occasionId String
  productId  String
  occasion   Occasion @relation(fields: [occasionId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0)

  @@id([occasionId, productId])
}

model Collection {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  description String?
  imageUrl    String?
  isActive    Boolean             @default(true)
  isFeatured  Boolean             @default(false)
  sortOrder   Int                 @default(0)
  products    CollectionProduct[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model CollectionProduct {
  collectionId String
  productId    String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)

  @@id([collectionId, productId])
}

model Bundle {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  imageUrl    String?
  price       Decimal      @db.Decimal(10, 2)
  isActive    Boolean      @default(true)
  validFrom   DateTime?
  validUntil  DateTime?
  items       BundleItem[]
  orderItems  OrderItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model BundleItem {
  id        String  @id @default(cuid())
  bundleId  String
  bundle    Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  variantId String?
}

model DeliveryZone {
  id            String         @id @default(cuid())
  name          String
  districts     String[]
  fee           Decimal        @db.Decimal(10, 2)
  freeThreshold Decimal?       @db.Decimal(10, 2)
  isActive      Boolean        @default(true)
  slots         DeliverySlot[]
  orders        Order[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model DeliverySlot {
  id          String        @id @default(cuid())
  zoneId      String?
  zone        DeliveryZone? @relation(fields: [zoneId], references: [id])
  dayOfWeek   Int[]
  startTime   String
  endTime     String
  capacity    Int           @default(10)
  isActive    Boolean       @default(true)
  orders      Order[]
  closedDates DateTime[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  guestEmail      String?
  guestPhone      String?
  addressId       String?
  address         Address?      @relation(fields: [addressId], references: [id])
  zoneId          String?
  zone            DeliveryZone? @relation(fields: [zoneId], references: [id])
  slotId          String?
  slot            DeliverySlot? @relation(fields: [slotId], references: [id])
  deliveryDate    DateTime?
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus @default(PENDING)
  stripePaymentId String?
  iyzicoPaymentId String?
  subtotal        Decimal       @db.Decimal(10, 2)
  deliveryFee     Decimal       @default(0) @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  pointsUsed      Int           @default(0)
  pointsEarned    Int           @default(0)
  discountCodeId  String?
  discountCode    DiscountCode? @relation(fields: [discountCodeId], references: [id])
  giftNote        String?
  isGift          Boolean       @default(false)
  adminNote       String?
  items           OrderItem[]
  timeline        OrderTimeline[]
  payments        Payment[]
  invoice         Invoice?
  corporateAccountId String?
  corporateAccount   CorporateAccount? @relation("CorporateOrders", fields: [corporateAccountId], references: [id])
  approvalRequest    OrderApproval?
  bulkOrderId        String?
  bulkOrder          BulkOrder?        @relation("BulkOrders", fields: [bulkOrderId], references: [id])
  salesContract      SalesContract?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?        @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  bundleId    String?
  bundle      Bundle?         @relation(fields: [bundleId], references: [id])
  name        String
  variantName String?
  price       Decimal         @db.Decimal(10, 2)
  quantity    Int             @default(1)
  total       Decimal         @db.Decimal(10, 2)
}

model OrderTimeline {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdBy String?
  createdAt DateTime    @default(now())
}

model Review {
  id           String       @id @default(cuid())
  productId    String
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  rating       Int
  title        String?
  body         String
  images       String[]
  status       ReviewStatus @default(PENDING)
  isPinned     Boolean      @default(false)
  adminReply   String?
  helpfulCount Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model LoyaltyTransaction {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int
  type        String
  description String
  orderId     String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

model DiscountCode {
  id               String       @id @default(cuid())
  code             String       @unique
  type             DiscountType
  value            Decimal      @db.Decimal(10, 2)
  minOrderAmount   Decimal?     @db.Decimal(10, 2)
  maxUses          Int?
  usedCount        Int          @default(0)
  perUserLimit     Int          @default(1)
  isFirstOrderOnly Boolean      @default(false)
  validFrom        DateTime?
  validUntil       DateTime?
  isActive         Boolean      @default(true)
  orders           Order[]
  affiliate        Affiliate?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?
  content     String
  coverImage  String?
  status      BlogStatus @default(DRAFT)
  publishedAt DateTime?
  scheduledAt DateTime?
  readingMins Int        @default(3)
  isFeatured  Boolean    @default(false)
  occasions   Occasion[] @relation("OccasionPosts")
  tags        BlogTag[]  @relation("PostTags")
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  viewCount   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model BlogTag {
  id    String     @id @default(cuid())
  name  String     @unique
  slug  String     @unique
  posts BlogPost[] @relation("PostTags")
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     Json
  isPublished Boolean  @default(false)
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MediaLibrary {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  sizeBytes Int
  altText   String?
  width     Int?
  height    Int?
  usedIn    String[]
  createdAt DateTime @default(now())
}

model CustomerSegment {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  rules       Json
  userCount   Int      @default(0)
  users       User[]   @relation("SegmentUsers")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CustomerTag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#C4622D")
  users User[] @relation("TagUsers")
}

model CRMNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      String
  createdBy String
  createdAt DateTime @default(now())
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  description String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  subject   String
  htmlBody  String
  variables String[]
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id         String    @id @default(cuid())
  to         String
  subject    String
  templateId String?
  status     String
  resendId   String?
  openedAt   DateTime?
  clickedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model SMSLog {
  id        String   @id @default(cuid())
  to        String
  body      String
  status    String
  provider  String   @default("netgsm")
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  isActive       Boolean   @default(true)
  source         String?
  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
}

model QuestionnaireResponse {
  id                String   @id @default(cuid())
  userId            String?
  sessionId         String?
  occasion          String?
  guestCount        String?
  date              String?
  budget            String?
  dietaryNeeds      String[]
  serviceStyle      String?
  notes             String?
  suggestedProducts String[]
  createdAt         DateTime @default(now())
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  sessionId String
  messages  Json
  converted Boolean  @default(false)
  orderId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String    @id @default(cuid())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  ipAddress   String?
  createdAt   DateTime  @default(now())
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ─── BOOKING SYSTEM ────────────────────────────────────

enum BookingStatus {
  PENDING
  CONFIRMED
  DEPOSIT_PAID
  COMPLETED
  CANCELLED
  NO_SHOW
}

model ServiceBooking {
  id              String           @id @default(cuid())
  bookingNumber   String           @unique @default(cuid())
  serviceSlug     String
  packageName     String
  packagePrice    Decimal          @db.Decimal(10, 2)
  depositAmount   Decimal          @db.Decimal(10, 2)
  depositPaid     Boolean          @default(false)
  status          BookingStatus    @default(PENDING)
  userId          String?
  user            User?            @relation(fields: [userId], references: [id])
  guestName       String
  guestEmail      String
  guestPhone      String
  guestCount      Int
  bookedDate      DateTime
  startTime       String
  endTime         String
  address         String?
  notes           String?
  adminNote       String?
  stripePaymentId String?
  cancelledAt     DateTime?
  cancelReason    String?
  reminderSent    Boolean          @default(false)
  timeline        BookingTimeline[]
  payments        Payment[]
  invoice         Invoice?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model BookingTimeline {
  id        String         @id @default(cuid())
  bookingId String
  booking   ServiceBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  status    BookingStatus
  note      String?
  createdBy String?
  createdAt DateTime       @default(now())
}

// ─── STOCK MANAGEMENT ──────────────────────────────────

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  type      String   // "IN", "OUT", "ADJUSTMENT"
  quantity  Int
  note      String?
  createdBy String?
  createdAt DateTime @default(now())
}

model AvailabilityRule {
  id            String   @id @default(cuid())
  serviceSlug   String
  dayOfWeek     Int
  startTime     String
  endTime       String
  slotMinutes   Int      @default(180)
  bufferMinutes Int      @default(60)
  maxBookings   Int      @default(1)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BlockedDate {
  id          String   @id @default(cuid())
  date        DateTime
  serviceSlug String?
  reason      String?
  startTime   String?
  endTime     String?
  createdAt   DateTime @default(now())
}

// ─── PAYMENT SYSTEM ────────────────────────────────────

model Payment {
  id                String            @id @default(cuid())
  orderId           String?
  order             Order?            @relation(fields: [orderId], references: [id])
  bookingId         String?
  booking           ServiceBooking?   @relation(fields: [bookingId], references: [id])
  amount            Decimal           @db.Decimal(10, 2)
  currency          String            @default("TRY")
  provider          PaymentProvider
  providerPaymentId String?
  providerStatus    String?
  status            PaymentStatus
  method            PaymentMethodType
  last4             String?
  cardBrand         String?
  installments      Int               @default(1)
  refunds           Refund[]
  metadata          Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Refund {
  id               String   @id @default(cuid())
  paymentId        String
  payment          Payment  @relation(fields: [paymentId], references: [id])
  amount           Decimal  @db.Decimal(10, 2)
  reason           String?
  providerRefundId String?
  status           String   // "pending", "succeeded", "failed"
  initiatedBy      String
  createdAt        DateTime @default(now())
}

model Invoice {
  id             String          @id @default(cuid())
  orderId        String?         @unique
  order          Order?          @relation(fields: [orderId], references: [id])
  bookingId      String?         @unique
  booking        ServiceBooking? @relation(fields: [bookingId], references: [id])
  invoiceNo      String          @unique
  pdfUrl         String?
  issuedAt       DateTime        @default(now())
  totalAmount    Decimal         @db.Decimal(10, 2)
  taxAmount      Decimal         @db.Decimal(10, 2)
  taxRate        Decimal         @default(0.08) @db.Decimal(4, 2)
  billingName    String
  billingEmail   String
  billingAddress String?
  companyName    String?
  taxNumber      String?
  createdAt      DateTime        @default(now())
}

// ─── MARKETING & CAMPAIGNS ─────────────────────────────

enum PopupType {
  EMAIL_CAPTURE
  DISCOUNT
  ANNOUNCEMENT
  EXIT_INTENT
  COOKIE_CONSENT
}

enum PopupTrigger {
  TIME_DELAY
  SCROLL_DEPTH
  EXIT_INTENT
  PAGE_LOAD
  CLICK
}

enum ReferralStatus {
  PENDING
  REGISTERED
  CONVERTED
  REWARDED
}

enum ABTestStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

model Popup {
  id               String       @id @default(cuid())
  name             String
  type             PopupType
  title            String
  subtitle         String?
  body             String?
  imageUrl         String?
  ctaText          String?
  ctaUrl           String?
  inputPlaceholder String?
  trigger          PopupTrigger
  triggerDelay     Int?
  triggerScroll    Int?
  showOnPages      String[]
  excludePages     String[]
  showOnDevices    String[]
  showOnce         Boolean      @default(true)
  showAfterDays    Int?
  maxShows         Int?
  targetSegment    String?
  newVisitorOnly   Boolean      @default(false)
  position         String       @default("center")
  bgColor          String       @default("#FFFFFF")
  textColor        String       @default("#3D1A0A")
  isActive         Boolean      @default(false)
  validFrom        DateTime?
  validUntil       DateTime?
  impressions      Int          @default(0)
  conversions      Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Banner {
  id          String    @id @default(cuid())
  name        String
  content     String
  linkUrl     String?
  bgColor     String    @default("#C4622D")
  textColor   String    @default("#FFFFFF")
  isCloseable Boolean   @default(true)
  position    String    @default("top")
  isActive    Boolean   @default(false)
  validFrom   DateTime?
  validUntil  DateTime?
  showOnPages String[]
  priority    Int       @default(0)
  clicks      Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Referral {
  id             String         @id @default(cuid())
  referrerId     String
  referrer       User           @relation("ReferralsMade", fields: [referrerId], references: [id])
  referredEmail  String
  referredUserId String?        @unique
  referredUser   User?          @relation("ReferralReceived", fields: [referredUserId], references: [id])
  status         ReferralStatus @default(PENDING)
  referrerReward Int            @default(0)
  referredReward String?
  convertedAt    DateTime?
  createdAt      DateTime       @default(now())
}

model FlashSale {
  id        String             @id @default(cuid())
  name      String
  startAt   DateTime
  endAt     DateTime
  isActive  Boolean            @default(false)
  products  FlashSaleProduct[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model FlashSaleProduct {
  id            String       @id @default(cuid())
  flashSaleId   String
  flashSale     FlashSale    @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
