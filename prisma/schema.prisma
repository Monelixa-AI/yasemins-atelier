  programDescription       String?
  pointsPerSpend           Decimal  @default(1.0) @db.Decimal(6, 2)
  spendPerPoints           Decimal  @default(100.0) @db.Decimal(8, 2)
  pointsToTLRate           Decimal  @default(1.0) @db.Decimal(6, 2)
  minPointsToRedeem        Int      @default(50)
  maxRedeemPercent         Int      @default(50)
  pointsExpireEnabled      Boolean  @default(false)
  pointsExpireDays         Int      @default(365)
  bonusFirstOrder          Boolean  @default(true)
  bonusFirstOrderPoints    Int      @default(50)
  bonusReview              Boolean  @default(true)
  bonusReviewPoints        Int      @default(10)
  bonusPhotoReview         Boolean  @default(true)
  bonusPhotoReviewPoints   Int      @default(20)
  bonusReferral            Boolean  @default(true)
  bonusReferralPoints      Int      @default(50)
  bonusBirthday            Boolean  @default(true)
  bonusBirthdayPoints      Int      @default(100)
  bonusNewsletter          Boolean  @default(true)
