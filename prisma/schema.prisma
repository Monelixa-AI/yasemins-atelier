  silverMultiplier         Decimal  @default(1.2) @db.Decimal(4, 2)
  goldMultiplier           Decimal  @default(1.5) @db.Decimal(4, 2)
  bronzeFreeShipping       Decimal? @db.Decimal(8, 2)
  silverFreeShipping       Decimal? @db.Decimal(8, 2)
  goldFreeShipping         Decimal? @db.Decimal(8, 2)
