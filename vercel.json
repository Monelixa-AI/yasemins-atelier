{
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/expire-points",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/monthly-report",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/instagram/refresh-token?secret=CRON_SECRET",
      "schedule": "0 9 1 * *"
    }
  ],
  "functions": {
    "api/webhooks/stripe.ts": {
      "maxDuration": 30
    },
    "api/orders/*/contract.ts": {
      "maxDuration": 60
    },
    "api/admin/reports/**": {
      "maxDuration": 30
    },
    "api/cron/monthly-report.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/webhooks/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
